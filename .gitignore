# dependencies / build output
node_modules/
dist/
.vite/
RCSprint-web.zip
# electron-builder output (the .exe ships as a GitHub Release asset, never committed)
release/

# local env / OS
*.local
.env
.DS_Store
Thumbs.db

# tooling
.playwright-mcp/
.claude/*.lock
.claude/scheduled_tasks.lock

# Verification screenshots & scratch files (ROOT ONLY — keeps public/**, src/assets/**).
# Captures belong in the session scratchpad, not here; these patterns are the safety net.
/*.png
/*.jpeg
/*.jpg
/*.txt
/*.log
/*.html
/$SCRATCH/
# ...but the real reference photos ARE tracked
!/ref-*.jpg
!/run-ref-*.jpg
